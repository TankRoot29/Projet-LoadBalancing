#!/bin/bash
# Configuration des interfaces
ip address add 100.0.0.3/24 dev eth0
ip address add 10.0.1.5/24 dev eth1

# Activer le forwarding IP
echo 1 > /proc/sys/net/ipv4/ip_forward

# ----- LOAD BALANCING WEB (port 80 TCP) -----
# Répartition 50/50 entre server1 et server2
iptables-legacy --table nat --append PREROUTING --destination 100.0.0.3 -p tcp --dport 80 -m statistic --mode random --probability 0.5 --jump DNAT --to-destination 10.0.1.1:80
iptables-legacy --table nat --append PREROUTING --destination 100.0.0.3 -p tcp --dport 80 --jump DNAT --to-destination 10.0.1.2:80

# NAT pour le retour des paquets
iptables-legacy --table nat --append POSTROUTING -o eth0 -j MASQUERADE

echo "Web Load Balancer configuré avec succès !"
echo "Web backend: 10.0.1.1 (server1) et 10.0.1.2 (server2)"