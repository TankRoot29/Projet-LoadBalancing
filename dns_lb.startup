#!/bin/bash
# Configuration des interfaces
ip address add 100.0.0.2/24 dev eth0
ip address add 10.0.0.5/24 dev eth1

# Activer le forwarding IP
echo 1 > /proc/sys/net/ipv4/ip_forward

# ----- LOAD BALANCING DNS (port 53 UDP) -----
# Répartition 50/50 entre dnsroot1 et dnsroot2
iptables-legacy --table nat --append PREROUTING --destination 100.0.0.2 -p udp --dport 53 -m statistic --mode random --probability 0.5 --jump DNAT --to-destination 10.0.0.1:53
iptables-legacy --table nat --append PREROUTING --destination 100.0.0.2 -p udp --dport 53 --jump DNAT --to-destination 10.0.0.2:53

# NAT pour le retour des paquets
iptables-legacy --table nat --append POSTROUTING -o eth0 -j MASQUERADE

echo "DNS Load Balancer configuré avec succès !"
echo "DNS backend: 10.0.0.1 (dnsroot1) et 10.0.0.2 (dnsroot2)"